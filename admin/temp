import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.1/firebase-app.js";
import { getDatabase, ref, push, set } from "https://www.gstatic.com/firebasejs/10.8.1/firebase-database.js";

// Uruchamiamy bazę
  const app = initializeApp(firebaseConfig);
  const db = getDatabase(app);

  // Reakcja na kliknięcie przycisku "Opublikuj wpis"
  document.getElementById('zapisz-btn').addEventListener('click', () => {
      const tytul = document.getElementById('name').value;
      const opis = document.getElementById('description').value;    
      const tresc = document.getElementById('content').value;

      if(tytul === "" || tresc === "") {
          alert("Musisz wypełnić tytuł i treść!");
          return;
      }

      // Wybieramy miejsce "wpisy" w bazie i generujemy unikalne ID posta (push)
      const wpisyRef = ref(db, 'wpisy');
      const nowyWpisRef = push(wpisyRef);

      // Zapisujemy dane
      set(nowyWpisRef, {
          tytul: tytul,
          opis: opis,
          tresc: tresc,
          data: Date.now() // Zapisujemy dokładny czas, żeby potem sortować od najnowszych
      }).then(() => {
          // Jeśli się uda, czyścimy pola i pokazujemy komunikat
          document.getElementById('komunikat-sukces').style.display = 'block';
          document.getElementById('name').value = '';
          document.getElementById('description').value = '';
          document.getElementById('content').value = '';
          setTimeout(() => { document.getElementById('komunikat-sukces').style.display = 'none'; }, 3000);
      }).catch((error) => {
          console.error(error);
          alert("Wystąpił błąd podczas zapisywania do bazy danych.");
      });
  });